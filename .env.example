# Copy to .env and fill in. Never commit .env.

# --- Telegram bot (from BotFather) ---
BOT_TOKEN=
# Telegram API credentials (https://my.telegram.org), for the Premium userbot uploader
API_ID=
API_HASH=
# Premium userbot session string (for uploads up to 4GB). Single-instance only!
PREMIUM_SESSION=

# --- Access control ---
# Comma-separated Telegram user IDs that are admins (first admin = you)
ADMIN_IDS=

# --- UI language ---
# Fallback language for users who haven't picked one (en, he, or any locales/<code>.json).
# Users can switch in-bot via 🌐 Language. Default: en.
DEFAULT_LANG=en

# --- unshackle REST API (unshackle serve) ---
UNSHACKLE_API=http://127.0.0.1:8786/api
# API key if `unshackle serve` runs without --no-key (leave empty if --no-key)
UNSHACKLE_API_KEY=

# --- Service catalog routing (all optional; the bot works with none of these set) ---
# Categorise services in the picker. A service can also declare its own category; an
# admin can override per-service from inside the bot. JSON: {"TAG": "il"|"free"|"sub"}.
CATEGORY_SEEDS=
# Fast URL routing by domain (otherwise each service's own title_regex/url is scanned).
# JSON: {"example.com": "TAG", "youtu.be": "YT"}
DOMAIN_SERVICES=
# Services that are free even though they accept an optional login. JSON list: ["TAG", ...]
FREE_SERVICES=
# Service tag that handles any otherwise-unmatched http link (e.g. a yt-dlp service). Empty = none.
CATCHALL_SERVICE=
# Service tag that handles podcast/RSS feed URLs. Empty = none.
FEED_SERVICE=

# IANA timezone for fixed-time monitor schedules (e.g. Asia/Jerusalem). Default: UTC.
SCHEDULE_TZ=UTC

# Services whose media SEGMENTS are geo-locked (not just the manifest/license). By default
# segment fetches bypass the proxy for speed. List any service whose CDN blocks foreign IPs here
# so all segment traffic also routes through the region proxy. JSON list: ["STING", "CELLCOM"]
SEGMENT_PROXY_SERVICES=

# --- Paths (defaults match the docker-compose ./data volume mounted at /data) ---
# unshackle's cookies dir (per-user cookies: <SERVICE>/<profile>.txt), MUST match unshackle.yaml
COOKIES_DIR=/data/cookies
# unshackle's downloads dir (where finished files land)
DOWNLOADS_DIR=/data/downloads
# bot runtime state (users.json, accounts.json, categories.json, uploader session)
STATE_DIR=/data/state
# per-user .wvd CDM devices (MUST equal unshackle.yaml directories.wvds)
WVD_DIR=/data/wvd
# Fernet key for encrypting stored credentials at rest (generate once; keep secret)
ENCRYPTION_KEY=
